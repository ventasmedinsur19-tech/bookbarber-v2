<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - BookBarber</title>
    <style>
        body { font-family: sans-serif; background: #0f0f0f; color: white; margin: 0; padding: 20px; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333; padding-bottom: 10px; }
        .trial-counter { background: #e74c3c; padding: 10px 20px; border-radius: 50px; font-weight: bold; font-size: 14px; }
        .pricing-info { background: #1a1a1a; padding: 15px; border-radius: 10px; margin-top: 20px; border-left: 5px solid #f39c12; }
        .sucursales-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .card { background: #1a1a1a; padding: 20px; border-radius: 12px; border: 1px solid #333; text-align: center; }
        .btn-add { background: #f39c12; color: black; border: none; padding: 15px; border-radius: 8px; font-weight: bold; cursor: pointer; width: 100%; margin-top: 10px; }
        .btn-pay { background: #25d366; color: white; text-decoration: none; padding: 10px; display: block; border-radius: 8px; margin-top: 10px; text-align: center; font-size: 14px; }
    </style>
</head>
<body>
    <div class="header">
        <h2>Panel de Control</h2>
        <div class="trial-counter">Quedan <%= diasRestantes %> días de prueba</div>
    </div>

    <div class="pricing-info">
        <p>Suscripción mensual: <strong>$15.000</strong></p>
        <p style="font-size: 13px; color: #aaa;">Cada sucursal extra suma $5.000 al valor total.</p>
        <a href="https://wa.me/3515920795?text=Hola,%20quiero%20abonar%20mi%20suscripcion" class="btn-pay">Activar Suscripción</a>
    </div>

    <h3>Tus Sucursales</h3>
    <div class="sucursales-grid">
        <% sucursales.forEach(sucursal => { %>
            <div class="card">
                <h4><%= sucursal.nombre %></h4>
                <p><%= sucursal.direccion || 'Dirección no cargada' %></p>
                <button class="btn-add" style="background: #333; color: white;">Configurar Sucursal</button>
            </div>
        <% }) %>
        
        <div class="card" style="border: 2px dashed #444; background: transparent;">
            <h4>¿Tienes más locales?</h4>
            <p>Agrega una sucursal extra por $5.000 adicionales.</p>
            <button class="btn-add">+ Agregar Sucursal</button>
        </div>
    </div>

    <div style="margin-top: 50px; text-align: center; color: #666; font-size: 12px;">
        <p>&copy; MedinSur Dev | <a href="https://wa.me/3513009673?text=Solicito%20una%20mejora" style="color: #f39c12; text-decoration: none;">Solicitar mejora</a></p>
    </div>
</body>
</html>

