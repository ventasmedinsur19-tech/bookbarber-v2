<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Servicios | BookBarber</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>body { background-color: #0f0f0f; color: #f0f0f0; }</style>
</head>
<body class="p-4">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
            <a href="/dashboard" class="text-orange-500"><i class="fas fa-arrow-left"></i> Volver</a>
            <h1 class="text-2xl font-bold">Gestión de Servicios</h1>
        </div>

        <!-- Formulario de Alta -->
        <div class="bg-[#1a1a1a] p-6 rounded-xl border border-gray-800 mb-8">
            <h2 class="text-lg font-bold mb-4 text-orange-500">Nuevo Servicio</h2>
            <form action="/servicios/guardar" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Sucursal</label>
                    <select name="sucursal_id" required class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm text-white">
                        <% sucursales.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.nombre %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Nombre del Servicio</label>
                    <input type="text" name="nombre" placeholder="Ej: Corte Clásico" required class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm text-white outline-none focus:border-orange-500">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Precio (USD/Local)</label>
                    <input type="number" step="0.01" name="precio" placeholder="0.00" required class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm text-white">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Duración (Minutos)</label>
                    <select name="duracion" class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm text-white">
                        <option value="15">15 min</option>
                        <option value="30" selected>30 min</option>
                        <option value="45">45 min</option>
                        <option value="60">1 hora</option>
                        <option value="90">1.5 horas</option>
                    </select>
                </div>
                <div class="md:col-span-2">
                    <button type="submit" class="w-full bg-orange-500 text-black font-bold py-3 rounded mt-2 hover:bg-orange-600 transition">
                        Agregar Servicio
                    </button>
                </div>
            </form>
        </div>

        <!-- Listado por Categorías (Wildcard: Promociones) -->
        <div class="space-y-6">
            <% const categorias = [...new Set(servicios.map(s => s.categoria || 'General'))]; %>
            <% categorias.forEach(cat => { %>
                <div>
                    <h3 class="text-orange-500 text-sm font-bold uppercase tracking-wider mb-3"><%= cat %></h3>
                    <div class="grid grid-cols-1 gap-3">
                        <% servicios.filter(s => (s.categoria || 'General') === cat).forEach(s => { %>
                            <div class="bg-[#1a1a1a] p-4 rounded-lg border border-gray-800 flex justify-between items-center">
                                <div>
                                    <h4 class="font-bold"><%= s.nombre %></h4>
                                    <p class="text-xs text-gray-500"><%= s.duracion %> min | <span class="text-white">$<%= s.precio %></span></p>
                                </div>
                                <div class="flex gap-3">
                                    <button class="text-gray-500 hover:text-white"><i class="fas fa-edit"></i></button>
                                    <button class="text-red-900 hover:text-red-500"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>

