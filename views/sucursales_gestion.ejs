<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sucursales | BookBarber</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://widget.cloudinary.com/v2.0/global/all.js" type="text/javascript"></script>
    <style>body { background-color: #0f0f0f; color: #f0f0f0; }</style>
</head>
<body class="p-4">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
            <a href="/dashboard" class="text-orange-500"><i class="fas fa-arrow-left"></i> Volver</a>
            <h1 class="text-2xl font-bold">Mis Sucursales</h1>
        </div>

        <div class="bg-[#1a1a1a] p-6 rounded-xl border border-gray-800 mb-8">
            <h2 class="text-lg font-bold mb-4 text-orange-500">Nueva Sucursal</h2>
            <form action="/sucursales/guardar" method="POST" class="grid grid-cols-1 gap-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Nombre</label>
                        <input type="text" name="nombre" required class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm text-white focus:border-orange-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Dirección</label>
                        <input type="text" name="direccion" class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm text-white">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Logo</label>
                        <button type="button" onclick="subir('logo')" class="w-full bg-gray-800 border border-dashed border-gray-600 p-2 rounded text-xs hover:bg-gray-700">
                            <i class="fas fa-upload mr-2"></i> <span id="txt-logo">Cargar Logo</span>
                        </button>
                        <input type="hidden" name="logo_url" id="input-logo">
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Foto Local</label>
                        <button type="button" onclick="subir('foto')" class="w-full bg-gray-800 border border-dashed border-gray-600 p-2 rounded text-xs hover:bg-gray-700">
                            <i class="fas fa-camera mr-2"></i> <span id="txt-foto">Cargar Foto</span>
                        </button>
                        <input type="hidden" name="foto_url" id="input-foto">
                    </div>
                </div>

                <button type="submit" class="w-full bg-orange-500 text-black font-bold py-3 rounded mt-4">Guardar Sucursal</button>
            </form>
        </div>

        <div class="space-y-4">
            <% sucursales.forEach(s => { %>
                <div class="bg-[#1a1a1a] p-4 rounded-lg border border-gray-800 flex justify-between items-center">
                    <div class="flex items-center gap-4">
                        <img src="<%= s.logo_url || 'https://via.placeholder.com/100?text=Barber' %>" class="w-12 h-12 rounded object-cover border border-gray-700">
                        <div>
                            <h3 class="font-bold text-white"><%= s.nombre %></h3>
                            <p class="text-xs text-gray-500"><%= s.direccion %></p>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        function subir(tipo) {
            cloudinary.openUploadWidget({
                cloudName: 'daffkqpnx',
                uploadPreset: 'bookbarber',
                sources: ['local', 'camera'],
                multiple: false
            }, (error, result) => {
                if (!error && result.event === "success") { 
                    document.getElementById('input-' + tipo).value = result.info.secure_url;
                    document.getElementById('txt-' + tipo).innerText = "¡Listo!";
                    document.getElementById('txt-' + tipo).style.color = "#22c55e";
                }
            });
        }
    </script>
</body>
</html>
