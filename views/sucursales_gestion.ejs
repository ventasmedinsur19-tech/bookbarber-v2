<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sucursales | MedinSur Dev</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>body { background-color: #0f0f0f; color: #f0f0f0; }</style>
</head>
<body class="p-4">

    <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
            <a href="/dashboard" class="text-orange-500"><i class="fas fa-arrow-left"></i> Volver</a>
            <h1 class="text-2xl font-bold">Gestión de Sucursales</h1>
        </div>

        <!-- Formulario de Carga -->
        <div class="bg-[#1a1a1a] p-6 rounded-xl border border-gray-800 mb-8">
            <h2 class="text-lg font-bold mb-4 text-orange-500">Registrar Nueva Sucursal</h2>
            <form action="/sucursales/guardar" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Nombre de la Barbería *</label>
                    <input type="text" name="nombre" required class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm focus:outline-none focus:border-orange-500">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Dirección</label>
                    <input type="text" name="direccion" class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">URL del Logo (Opcional)</label>
                    <input type="text" name="logo_url" placeholder="https://..." class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">URL Foto del Local (Opcional)</label>
                    <input type="text" name="foto_url" placeholder="https://..." class="w-full bg-[#2a2a2a] border border-gray-700 rounded p-2 text-sm">
                </div>
                <div class="md:col-span-2 mt-2">
                    <button type="submit" class="w-full bg-orange-500 text-black font-bold py-2 rounded hover:bg-orange-600 transition">
                        Guardar Sucursal
                    </button>
                </div>
            </form>
        </div>

        <!-- Lista de Sucursales Actuales -->
        <h2 class="text-lg font-bold mb-4">Tus Locales</h2>
        <div class="space-y-4">
            <% sucursales.forEach(s => { %>
                <div class="bg-[#1a1a1a] p-4 rounded-lg border border-gray-800 flex justify-between items-center">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-gray-800 rounded flex items-center justify-center overflow-hidden">
                            <% if(s.logo_url) { %>
                                <img src="<%= s.logo_url %>" class="object-cover w-full h-full">
                            <% } else { %>
                                <i class="fas fa-store text-gray-600"></i>
                            <% } %>
                        </div>
                        <div>
                            <h3 class="font-bold"><%= s.nombre %></h3>
                            <p class="text-xs text-gray-500"><%= s.direccion || 'Sin dirección registrada' %></p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button class="text-gray-400 hover:text-white p-2"><i class="fas fa-edit"></i></button>
                        <button class="text-red-900 hover:text-red-500 p-2"><i class="fas fa-trash"></i></button>
                    </div>
                </div>
            <% }) %>
        </div>

        <p class="text-center text-[10px] text-gray-600 mt-10">© MedinSur Dev - BookBarber Online</p>
    </div>

</body>
</html>
