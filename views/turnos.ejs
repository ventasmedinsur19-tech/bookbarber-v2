<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestión de Turnos - BookBarber</title>
  <link rel="stylesheet" href="/css/styles.css"> <style>
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; margin: 0; padding: 20px; }
    .container { max-width: 1200px; margin: 0 auto; }
    header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    header h1 { color: #2c3e50; margin: 0; }
    .btn-back { background-color: #7f8c8d; color: white; text-decoration: none; padding: 10px 15px; border-radius: 5px; font-size: 0.9em; }
    .grid-turnos { display: grid; grid-template-columns: 1fr; gap: 20px; }
    @media (min-width: 768px) { .grid-turnos { grid-template-columns: 1fr 2fr; } }
    .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .card h2 { margin-top: 0; color: #34495e; border-bottom: 2px solid #ecf0f1; padding-bottom: 10px; }
    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: bold; color: #2c3e50; }
    .form-group input, .form-group select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; box-sizing: border-box; }
    .btn-submit { background-color: #27ae60; color: white; border: none; padding: 12px; width: 100%; border-radius: 5px; font-size: 1em; cursor: pointer; font-weight: bold; }
    .btn-submit:hover { background-color: #219150; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #e2e8f0; }
    th { background-color: #2c3e50; color: white; }
    .badge { padding: 5px 10px; border-radius: 20px; font-size: 0.85em; font-weight: bold; text-transform: uppercase; }
    .badge-pendiente { background-color: #f1c40f; color: #fff; }
    .badge-completado { background-color: #27ae60; color: #fff; }
    .badge-cancelado { background-color: #e74c3c; color: #fff; }
    .actions-form { display: inline-block; margin-right: 5px; }
    .btn-action { border: none; padding: 6px 10px; border-radius: 4px; color: white; cursor: pointer; font-weight: bold; }
    .btn-check { background-color: #2ecc71; }
    .btn-cancel { background-color: #e74c3c; }
    .btn-action:hover { opacity: 0.9; }
    .wa-link { color: #25d366; text-decoration: none; font-weight: bold; }
  </style>
</head>
<body>

<div class="container">
  <header>
    <h1>📅 Panel de Turnos</h1>
    <a href="/dashboard" class="btn-back">← Volver al Dashboard</a>
  </header>

  <div class="grid-turnos">
    
    <div class="card">
      <h2>Nuevo Turno</h2>
      <form action="/turnos/guardar" method="POST">
        
        <div class="form-group">
          <label for="barbero_id">Asignar Barbero:</label>
          <select name="barbero_id" id="barbero_id" required>
            <option value="">-- Seleccionar Profesional --</option>
            <% barberos.forEach(b => { %>
              <option value="<%= b.id %>"><%= b.nombre %> (<%= b.sucursal_nombre %>)</option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="servicio_id">Servicio requerido:</label>
          <select name="servicio_id" id="servicio_id" required>
            <option value="">-- Seleccionar Servicio --</option>
            <% servicios.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.nombre %> — $<%= s.precio %> (<%= s.sucursal_nombre %>)</option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="cliente_nombre">Nombre del Cliente:</label>
          <input type="text" name="cliente_nombre" id="cliente_nombre" placeholder="Ej: Carlos Gómez" required>
        </div>

        <div class="form-group">
          <label for="cliente_whatsapp">WhatsApp del Cliente:</label>
          <input type="tel" name="cliente_whatsapp" id="cliente_whatsapp" placeholder="Ej: 54911xxxxxxx" required>
        </div>

        <div class="form-group">
          <label for="fecha">Fecha del Turno:</label>
          <input type="date" name="fecha" id="fecha" required>
        </div>

        <div class="form-group">
          <label for="hora">Hora:</label>
          <input type="time" name="hora" id="hora" required>
        </div>

        <button type="submit" class="btn-submit">Agendar Turno</button>
      </form>
    </div>

    <div class="card">
      <h2>Lista de Turnos</h2>
      
      <% if (turnos.length === 0) { %>
        <p style="color: #7f8c8d; text-align: center; padding: 20px;">No hay turnos registrados en este momento.</p>
      <% } else { %>
        <div style="overflow-x: auto;">
          <table>
            <thead>
              <tr>
                <th>Horario</th>
                <th>Cliente</th>
                <th>Detalles</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% turnos.forEach(t => { %>
                <tr>
                  <td>
                    <strong><%= new Date(t.fecha).toLocaleDateString('es-ES', { timeZone: 'UTC' }) %></strong><br>
                    <small style="color: #555;"><%= t.hora.substring(0, 5) %> hs</small>
                  </td>
                  <td>
                    <strong><%= t.cliente_nombre %></strong><br>
                    <a href="https://wa.me/<%= t.cliente_whatsapp %>" target="_blank" class="wa-link">💬 WhatsApp</a>
                  </td>
                  <td>
                    <span style="font-size: 0.95em;"><%= t.servicio_nombre %></span><br>
                    <small style="color: #7f8c8d;"><%= t.barbero_nombre %> • <strong>$<%= t.precio %></strong></small><br>
                    <small style="font-style: italic; color: #95a5a6;"><%= t.sucursal_nombre %></small>
                  </td>
                  <td>
                    <span class="badge badge-<%= t.estado %>"><%= t.estado %></span>
                  </td>
                  <td>
                    <% if (t.estado === 'pendiente') { %>
                      <form action="/turnos/estado" method="POST" class="actions-form">
                        <input type="hidden" name="turno_id" value="<%= t.id %>">
                        <input type="hidden" name="nuevo_estado" value="completado">
                        <button type="submit" class="btn-action btn-check" title="Marcar como Completado">✓</button>
                      </form>
                      
                      <form action="/turnos/estado" method="POST" class="actions-form">
                        <input type="hidden" name="turno_id" value="<%= t.id %>">
                        <input type="hidden" name="nuevo_estado" value="cancelado">
                        <button type="submit" class="btn-action btn-cancel" title="Cancelar Turno">✕</button>
                      </form>
                    <% } else { %>
                      <small style="color: #bdc3c7;">Finalizado</small>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

    </div>
  </div>
</div>

</body>
</html>
