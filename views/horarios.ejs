<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Horarios | BookBarber Online</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        bbDark: '#0a0a0a',
                        bbCard: '#141414',
                        bbBorder: '#262626',
                        bbAccent: '#f97316'
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0a0a0a; color: #e5e5e5; }
        .glass-card { background: rgba(20, 20, 20, 0.7); backdrop-filter: blur(10px); border: 1px solid #262626; }
        /* Para que el desplegable se vea bien en celulares */
        select option { background-color: #141414; color: #fff; }
    </style>
</head>
<body class="font-sans antialiased selection:bg-bbAccent selection:text-white min-h-screen p-4 md:p-8">
    <div class="max-w-5xl mx-auto">
        
        <div class="flex items-center gap-4 mb-10 border-b border-bbBorder pb-6">
            <a href="/dashboard" class="flex items-center justify-center w-10 h-10 rounded-xl bg-bbBorder text-gray-400 hover:text-bbAccent hover:bg-bbAccent/10 transition-all">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="text-2xl md:text-3xl font-black text-white">Gestión de Horarios</h1>
                <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mt-1">Configura la agenda de tu staff</p>
            </div>
        </div>

        <div class="glass-card p-6 md:p-8 rounded-2xl mb-12 shadow-lg">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-lg bg-bbAccent/10 flex items-center justify-center text-bbAccent">
                    <i class="far fa-clock"></i>
                </div>
                <h2 class="text-lg font-bold text-white">Añadir Nuevo Turno Laboral</h2>
            </div>
            
            <form action="/horarios/guardar" method="POST" class="grid grid-cols-1 md:grid-cols-4 gap-6">
                
                <div class="md:col-span-4">
                    <label class="block text-xs text-gray-500 mb-2 font-bold uppercase tracking-wider">Asignar a Barbero</label>
                    <% if (barberos.length === 0) { %>
                        <div class="bg-red-500/10 border border-red-500/50 text-red-500 p-4 rounded-xl text-sm">
                            <i class="fas fa-exclamation-triangle mr-2"></i> No tienes barberos registrados. Ve a la sección <b>Staff</b> primero.
                        </div>
                    <% } else { %>
                        <select name="barbero_id" required class="w-full bg-bbDark border border-bbBorder rounded-xl p-4 text-sm text-white outline-none focus:border-bbAccent focus:ring-1 focus:ring-bbAccent transition-all appearance-none">
                            <% barberos.forEach(b => { %>
                                <option value="<%= b.id %>"><%= b.nombre %> (Sucursal: <%= b.sucursal_nombre %>)</option>
                            <% }) %>
                        </select>
                    <% } %>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs text-gray-500 mb-2 font-bold uppercase tracking-wider">Día de la semana</label>
                    <select name="dia" required class="w-full bg-bbDark border border-bbBorder rounded-xl p-4 text-sm text-white outline-none focus:border-bbAccent focus:ring-1 focus:ring-bbAccent transition-all appearance-none">
                        <option value="Lunes">Lunes</option>
                        <option value="Martes">Martes</option>
                        <option value="Miércoles">Miércoles</option>
                        <option value="Jueves">Jueves</option>
                        <option value="Viernes">Viernes</option>
                        <option value="Sábado">Sábado</option>
                        <option value="Domingo">Domingo</option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs text-gray-500 mb-2 font-bold uppercase tracking-wider">Apertura</label>
                    <input type="time" name="hora_inicio" required class="w-full bg-bbDark border border-bbBorder rounded-xl p-4 text-sm text-white outline-none focus:border-bbAccent focus:ring-1 focus:ring-bbAccent transition-all" style="color-scheme: dark;">
                </div>

                <div>
                    <label class="block text-xs text-gray-500 mb-2 font-bold uppercase tracking-wider">Cierre</label>
                    <input type="time" name="hora_fin" required class="w-full bg-bbDark border border-bbBorder rounded-xl p-4 text-sm text-white outline-none focus:border-bbAccent focus:ring-1 focus:ring-bbAccent transition-all" style="color-scheme: dark;">
                </div>

                <div class="md:col-span-4 mt-2">
                    <button type="submit" class="w-full bg-bbAccent text-black font-black uppercase tracking-widest py-4 rounded-xl hover:bg-orange-600 transition-all active:scale-[0.98] shadow-[0_0_20px_rgba(249,115,22,0.2)] disabled:opacity-50" <%= barberos.length === 0 ? 'disabled' : '' %>>
                        Guardar Horario
                    </button>
                </div>
            </form>
        </div>

        <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-bold text-white">Horarios Configurados</h3>
            <span class="bg-bbBorder text-gray-400 px-3 py-1 rounded-full text-xs font-bold"><%= horarios.length %> Registros</span>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            <% if (horarios.length === 0) { %>
                <div class="col-span-full glass-card p-10 flex flex-col items-center justify-center text-center rounded-2xl border-dashed border-2 border-bbBorder">
                    <i class="fas fa-calendar-times text-4xl text-gray-600 mb-4"></i>
                    <p class="text-gray-400 text-sm">No hay horarios configurados todavía.</p>
                    <p class="text-xs text-gray-600 mt-2">Añade el primer horario usando el formulario superior.</p>
                </div>
            <% } else { %>
                <% horarios.forEach(h => { %>
                    <div class="glass-card p-5 rounded-2xl group hover:border-bbAccent/50 transition-all duration-300 relative overflow-hidden">
                        
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <span class="inline-block px-2 py-1 bg-bbBorder rounded text-[10px] text-gray-400 font-bold uppercase mb-2">
                                    <i class="fas fa-store text-bbAccent mr-1"></i> <%= h.sucursal_nombre %>
                                </span>
                                <h4 class="font-black text-white text-lg flex items-center gap-2">
                                    <%= h.dia %>
                                </h4>
                            </div>
                            <button class="w-8 h-8 rounded-lg bg-red-500/10 text-red-500 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all">
                                <i class="fas fa-trash text-sm"></i>
                            </button>
                        </div>
                        
                        <div class="flex items-center gap-3 p-3 bg-bbDark rounded-xl border border-bbBorder">
                            <div class="w-10 h-10 rounded-full bg-bbBorder flex items-center justify-center text-gray-400">
                                <i class="fas fa-user-tie"></i>
                            </div>
                            <div>
                                <p class="text-[10px] text-gray-500 uppercase font-bold">Barbero asignado</p>
                                <p class="text-sm text-white font-semibold"><%= h.barbero_nombre %></p>
                            </div>
                        </div>

                        <div class="mt-4 flex items-center justify-between text-sm text-gray-300 font-medium">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-door-open text-green-500"></i>
                                <span><%= h.hora_inicio.substring(0,5) %> hs</span>
                            </div>
                            <div class="w-8 h-[1px] bg-bbBorder"></div>
                            <div class="flex items-center gap-2">
                                <i class="fas fa-door-closed text-red-500"></i>
                                <span><%= h.hora_fin.substring(0,5) %> hs</span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

    </div>
</body>
</html>
